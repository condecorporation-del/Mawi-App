# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# DATABASE_URL: modo Transaction (puerto 6543), con ?pgbouncer=true
# DIRECT_URL: conexión directa para migraciones (puerto 5432)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Deepgram (voz) ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── Agent ───────────────────────────────────────────────────────────────────
AGENT_RATE_LIMIT_RPM=20
